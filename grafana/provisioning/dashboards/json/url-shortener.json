{
  "id": null,
  "uid": "url-shortener-main",
  "title": "URL Shortener Dashboard",
  "schemaVersion": 39,
  "version": 2,
  "timezone": "browser",
  "refresh": "15s",
  "tags": ["url-shortener", "nodejs"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "🟢 Service Status",
      "type": "stat",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"url-shortener\"}", "legendFormat": "App", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "📈 Request Rate (req/s)",
      "type": "stat",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(http_requests_total[5m]))", "legendFormat": "req/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "⚠️ Error Rate",
      "type": "stat",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100 or vector(0)", "legendFormat": "Error %", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "🧠 Heap Memory Used",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 209715200 }] }
        }
      },
      "targets": [{ "expr": "nodejs_heap_size_used_bytes", "legendFormat": "Heap Used", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "⚡ Event Loop Lag",
      "type": "stat",
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] }
        }
      },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "Event Loop Lag", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "⏱ Process Uptime",
      "type": "stat",
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        }
      },
      "targets": [{ "expr": "process_uptime_seconds", "legendFormat": "Uptime", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "📊 HTTP Request Rate by Route",
      "type": "timeseries",
      "id": 7,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "sum by (route, method) (rate(http_requests_total[5m]))", "legendFormat": "{{method}} {{route}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "📉 Response Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "id": 8,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "title": "🧠 Node.js Memory (Heap Used vs Total)",
      "type": "timeseries",
      "id": 9,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "Heap Used", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "Heap Total", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "nodejs_external_memory_bytes", "legendFormat": "External", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "title": "🖥 CPU Usage",
      "type": "timeseries",
      "id": 10,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "CPU %", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "title": "🔢 HTTP Status Code Breakdown",
      "type": "piechart",
      "id": 11,
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [{ "expr": "sum by (status_code) (increase(http_requests_total[1h]))", "legendFormat": "{{status_code}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "🗑 Garbage Collection Duration",
      "type": "timeseries",
      "id": 12,
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [{ "expr": "rate(nodejs_gc_duration_seconds_sum[5m])", "legendFormat": "GC Duration", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "title": "📦 Active Handles & Requests",
      "type": "timeseries",
      "id": 13,
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "nodejs_active_handles_total", "legendFormat": "Active Handles", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "nodejs_active_requests_total", "legendFormat": "Active Requests", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
